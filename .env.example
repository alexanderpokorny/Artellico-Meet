# Jitsi Meet - Artellico
# Copy to .env and fill in values

# Public URL
PUBLIC_URL=https://meet.artellico.com

# Timezone
TZ=Europe/Vienna

# Config directory
CONFIG=~/.jitsi-meet-cfg

# JVB Network (CRITICAL: set to VPS public IP)
JVB_ADVERTISE_IPS=152.53.33.104
JVB_PORT=10000
JVB_STUN_SERVERS=stun:stun.l.google.com:19302

# Auth
ENABLE_AUTH=1
AUTH_TYPE=internal
ENABLE_GUESTS=1
ENABLE_LOBBY=1

# TLS via Coolify Traefik (no internal LE)
ENABLE_LETSENCRYPT=0

# Performance (small use case)
ENABLE_RECORDING=0

# JVM tuning for small VPS
JVB_JAVA_OPTIONS=-Xmx512m -Xms256m
JICOFO_JAVA_OPTIONS=-Xmx256m -Xms128m

# Security passwords (generate with: openssl rand -hex 16)
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
JICOFO_COMPONENT_SECRET=
